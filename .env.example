# Aliyun OSS credentials
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# OSS bucket settings
OSS_BUCKET_NAME=luke-chu-site-photography
OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com

# Optional custom public base URL
# OSS_PUBLIC_BASE_URL=https://luke-chu-site-photography.oss-cn-hongkong.aliyuncs.com

# Qwen model paths (required for generate_ai_metadata.py)
QWEN_MODEL_PATH=C:/path/to/Qwen3-VL-2B-Instruct
# Optional, if different from QWEN_MODEL_PATH
QWEN_PROCESSOR_PATH=C:/path/to/Qwen3-VL-2B-Instruct

# PostgreSQL connection (required for import_pg.py)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=luke-chu-site
PGUSER=admin
PGPASSWORD=1234
